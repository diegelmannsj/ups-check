#!/usr/bin/env python3
import subprocess
import socket
import sys
import os
import datetime
import argparse
import io
import re

# Terminal Colors
GREEN = '\033[92m'
RED = '\033[91m'
YELLOW = '\033[93m'
RESET = '\033[0m'
BOLD = '\033[1m'

VERSION = "1.1.0"

# Global buffer to capture output for logging
output_buffer = io.StringIO()

def strip_ansi(text):
    """Removes ANSI escape codes from a string."""
    ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])')
    return ansi_escape.sub('', text)

def cprint(text="", end="\n"):
    """Custom print that writes to buffer and handles tty colors gracefully."""
    # Write cleanly to stdout (stripping colors if user manually pipes the output)
    if not sys.stdout.isatty():
        print(strip_ansi(text), end=end)
    else:
        print(text, end=end)
    
    # Always write raw text to buffer; we will strip ANSI right before saving to log
    output_buffer.write(text + end)

def print_header(text):
    cprint(f"\n{BOLD}=== {text} ==={RESET}")

def run_cmd(cmd):
    """Executes a shell command and returns return code, stdout, and stderr."""
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except FileNotFoundError:
        return 127, "", "Command not found"

def check_service(service_name):
    """Checks systemd status and prints logs if failed."""
    code, stdout, stderr = run_cmd(["systemctl", "is-active", service_name])
    if stdout == "active":
        cprint(f"[{GREEN}?{RESET}] {service_name} is running.")
        return True
    else:
        cprint(f"[{RED}?{RESET}] {service_name} is NOT active (Status: {stdout}).")
        cprint(f"{YELLOW}Fetching recent logs for {service_name}...{RESET}")
        
        # Grab the last 15 log lines
        log_code, log_out, log_err = run_cmd(["journalctl", "-u", service_name, "-n", "15", "--no-pager"])
        if log_out:
            for line in log_out.split('\n'):
                cprint(f"    {line}")
        else:
            cprint("    (No logs found in journalctl)")
        return False

def check_failed_drivers():
    """Finds any specific instantiated driver services that crashed."""
    code, stdout, stderr = run_cmd(["systemctl", "list-units", "--state=failed", "nut-driver*"])
    lines = stdout.split('\n')
    failed_drivers = [line.strip() for line in lines if "nut-driver" in line and "failed" in line]
    
    if failed_drivers:
        cprint(f"\n[{RED}?{RESET}] Found failed UPS driver instances!")
        for driver in failed_drivers:
            # Extract just the service name from the systemctl output row
            svc_name = driver.split()[0]
            cprint(f"{YELLOW}Fetching logs for crashed driver: {svc_name}...{RESET}")
            log_code, log_out, log_err = run_cmd(["journalctl", "-u", svc_name, "-n", "15", "--no-pager"])
            if log_out:
                for line in log_out.split('\n'):
                    cprint(f"    {line}")
    else:
        cprint(f"[{GREEN}?{RESET}] No crashed hardware driver instances found.")

def check_port(host="127.0.0.1", port=3493):
    """Checks if the upsd socket is accepting connections."""
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(2)
        try:
            s.connect((host, port))
            cprint(f"[{GREEN}?{RESET}] upsd is actively listening on {host}:{port}.")
            return True
        except Exception as e:
            cprint(f"[{RED}?{RESET}] Connection failed on {host}:{port} - {e}")
            return False

def check_upsc():
    """Uses upsc to attempt a local data read."""
    print_header("Local Data Communication (upsc)")
    code, stdout, stderr = run_cmd(["upsc", "-l"])
    
    if code != 0:
        cprint(f"[{RED}?{RESET}] Failed to list UPS devices via upsc.")
        cprint(f"    Error Output: {stderr}")
        return

    devices = [d for d in stdout.split('\n') if d]
    if not devices:
        cprint(f"[{YELLOW}!{RESET}] Daemon responded, but no UPS devices are configured/detected.")
        return

    for dev in devices:
        cprint(f"[{GREEN}?{RESET}] Found UPS device registered: {BOLD}{dev}{RESET}")
        code_stat, out_stat, err_stat = run_cmd(["upsc", dev, "ups.status"])
        if code_stat == 0:
            cprint(f"    -> Current UPS Status: {BOLD}{GREEN}{out_stat}{RESET}")
        else:
            cprint(f"    -> [{RED}?{RESET}] Could not read status variables for {dev}.")
            cprint(f"       Error Output: {err_stat}")

def write_log():
    """Prepends the captured run data to today's log file."""
    log_dir = os.path.expanduser("~/.logs/upscheck/")
    os.makedirs(log_dir, exist_ok=True)
    
    date_str = datetime.datetime.now().strftime("%Y-%m-%d")
    time_str = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_file = os.path.join(log_dir, f"upscheck_{date_str}.log")
    
    new_content = strip_ansi(output_buffer.getvalue())
    header = f"--- Run at {time_str} ---\n"
    
    existing_content = ""
    if os.path.exists(log_file):
        with open(log_file, "r") as f:
            existing_content = f.read()
            
    with open(log_file, "w") as f:
        f.write(header + new_content + "\n" + existing_content)
        
    # Print to console normally (not the buffer) to confirm log was written
    print(f"\n[{GREEN}?{RESET}] Log successfully prepended to {log_file}")

def main():
    # Always print version first
    cprint(f"{BOLD}UPS Diagnostic Tool v{VERSION}{RESET}\n")
    
    parser = argparse.ArgumentParser(description="Diagnostic tool for checking NUT UPS services.")
    parser.add_argument("-l", "--log", action="store_true", help="Enable and prepend logging to ~/.logs/upscheck/")
    args = parser.parse_args()

    print_header("Systemd Service Health")
    services = [
        "nut-server.service",
        "nut-monitor.service",
        "nut-driver-enumerator.service"
    ]
    
    for svc in services:
        check_service(svc)
        
    check_failed_drivers()

    print_header("Network & Port Binding")
    check_port("127.0.0.1", 3493)
    
    check_upsc()
    cprint("")

    if args.log:
        write_log()

if __name__ == "__main__":
    main()