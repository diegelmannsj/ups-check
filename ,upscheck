#!/usr/bin/env python3
import subprocess
import socket
import sys

# Terminal Colors
GREEN = '\033[92m'
RED = '\033[91m'
YELLOW = '\033[93m'
RESET = '\033[0m'
BOLD = '\033[1m'

VERSION = "1.0.0"

def print_header(text):
    print(f"\n{BOLD}=== {text} ==={RESET}")

def run_cmd(cmd):
    """Executes a shell command and returns return code, stdout, and stderr."""
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except FileNotFoundError:
        return 127, "", "Command not found"

def check_service(service_name):
    """Checks systemd status and prints logs if failed."""
    code, stdout, stderr = run_cmd(["systemctl", "is-active", service_name])
    if stdout == "active":
        print(f"[{GREEN}?{RESET}] {service_name} is running.")
        return True
    else:
        print(f"[{RED}?{RESET}] {service_name} is NOT active (Status: {stdout}).")
        print(f"{YELLOW}Fetching recent logs for {service_name}...{RESET}")
        
        # Grab the last 15 log lines
        log_code, log_out, log_err = run_cmd(["journalctl", "-u", service_name, "-n", "15", "--no-pager"])
        if log_out:
            for line in log_out.split('\n'):
                print(f"    {line}")
        else:
            print("    (No logs found in journalctl)")
        return False

def check_failed_drivers():
    """Finds any specific instantiated driver services that crashed."""
    code, stdout, stderr = run_cmd(["systemctl", "list-units", "--state=failed", "nut-driver*"])
    lines = stdout.split('\n')
    failed_drivers = [line.strip() for line in lines if "nut-driver" in line and "failed" in line]
    
    if failed_drivers:
        print(f"\n[{RED}?{RESET}] Found failed UPS driver instances!")
        for driver in failed_drivers:
            # Extract just the service name from the systemctl output row
            svc_name = driver.split()[0]
            print(f"{YELLOW}Fetching logs for crashed driver: {svc_name}...{RESET}")
            log_code, log_out, log_err = run_cmd(["journalctl", "-u", svc_name, "-n", "15", "--no-pager"])
            if log_out:
                for line in log_out.split('\n'):
                    print(f"    {line}")
    else:
        print(f"[{GREEN}?{RESET}] No crashed hardware driver instances found.")

def check_port(host="127.0.0.1", port=3493):
    """Checks if the upsd socket is accepting connections."""
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(2)
        try:
            s.connect((host, port))
            print(f"[{GREEN}?{RESET}] upsd is actively listening on {host}:{port}.")
            return True
        except Exception as e:
            print(f"[{RED}?{RESET}] Connection failed on {host}:{port} - {e}")
            return False

def check_upsc():
    """Uses upsc to attempt a local data read."""
    print_header("Local Data Communication (upsc)")
    code, stdout, stderr = run_cmd(["upsc", "-l"])
    
    if code != 0:
        print(f"[{RED}?{RESET}] Failed to list UPS devices via upsc.")
        print(f"    Error Output: {stderr}")
        return

    devices = [d for d in stdout.split('\n') if d]
    if not devices:
        print(f"[{YELLOW}!{RESET}] Daemon responded, but no UPS devices are configured/detected.")
        return

    for dev in devices:
        print(f"[{GREEN}?{RESET}] Found UPS device registered: {BOLD}{dev}{RESET}")
        code_stat, out_stat, err_stat = run_cmd(["upsc", dev, "ups.status"])
        if code_stat == 0:
            print(f"    -> Current UPS Status: {BOLD}{GREEN}{out_stat}{RESET}")
        else:
            print(f"    -> [{RED}?{RESET}] Could not read status variables for {dev}.")
            print(f"       Error Output: {err_stat}")

def main():
    print(f"{BOLD}UPS Diagnostic Tool v{VERSION}{RESET}\n")
    
    print_header("Systemd Service Health")
    services = [
        "nut-server.service",
        "nut-monitor.service",
        "nut-driver-enumerator.service"
    ]
    
    for svc in services:
        check_service(svc)
        
    check_failed_drivers()

    print_header("Network & Port Binding")
    # Check localhost (where local upsmon connects)
    check_port("127.0.0.1", 3493)
    
    check_upsc()
    print("")

if __name__ == "__main__":
    main()